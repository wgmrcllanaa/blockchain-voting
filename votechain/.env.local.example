# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://postgres.jgcatebqrpgnstnjoqvp:[YOUR-PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres?sslmode=require"
