# ─── Database ─────────────────────────────────────────────────────────────────
# Replace with your actual PostgreSQL connection string
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/votechain"

# ─── Admin credentials ────────────────────────────────────────────────────────
ADMIN_USERNAME="acomss_admin"
ADMIN_PASSWORD="your_secure_password_here"

# ─── Contract (fill in after running: cd blockchain && npx hardhat run scripts/deploy.ts --network localhost) ──
NEXT_PUBLIC_CONTRACT_ADDRESS="0x"
NEXT_PUBLIC_ADMIN_ADDRESS="0x"

# ─── Blockchain network ───────────────────────────────────────────────────────
NEXT_PUBLIC_CHAIN_ID="31337"
NEXT_PUBLIC_RPC_URL="http://127.0.0.1:8545"
